---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ImageConverterTool from "../../components/image-converter/ImageConverterTool";

const pageTitle = "Image Converter — LocalKit";
const pageDescription =
  "Batch convert images between PNG, JPG, GIF, BMP, TIFF, HEIC, and more. All processing happens locally in your browser — your files never leave your device.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Image Converter",
  url: "https://localkit.dev/tools/image-converter",
  description: pageDescription,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  browserRequirements: "Requires WebAssembly support",
  isPartOf: {
    "@type": "WebSite",
    name: "LocalKit",
    url: "https://localkit.dev",
  },
};
---

<Layout title={pageTitle} description={pageDescription} ogImage="https://localkit.dev/og/image-converter.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full bg-accent-purple/6 blur-[120px]"></div>
      <div class="absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full bg-accent-indigo/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-4xl px-6">
      <!-- Header -->
      <div class="mb-8">
        <a href="/" class="mb-4 inline-flex items-center gap-1.5 text-xs text-text-muted transition-colors hover:text-text-secondary">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Back to tools
        </a>
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-accent-purple/20 bg-accent-purple/10">
            <svg class="h-5 w-5 text-accent-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
            </svg>
          </div>
          <div>
            <h1 class="font-display text-2xl font-bold text-text-primary">Image Converter</h1>
            <p class="text-sm text-text-muted">Batch convert between PNG, JPG, GIF, BMP, TIFF, HEIC, and more</p>
          </div>
        </div>
      </div>

      <!-- Privacy badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-card bg-bg-secondary px-3 py-1">
        <svg class="h-3.5 w-3.5 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-xs text-text-secondary">100% client-side — your images never leave your device</span>
      </div>

      <ImageConverterTool client:load />
    </div>
  </main>

  <Footer />
</Layout>
