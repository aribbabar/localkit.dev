---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CodeFormatterApp from "../../components/code-formatter/CodeFormatterApp";

const pageTitle = "Code Formatter — LocalKit";
const pageDescription =
  "Format, syntax-highlight, and export beautiful code images in 20+ languages — JavaScript, TypeScript, HTML, CSS, C, C++, Java, C#, JSON, YAML, and more. Powered by Prettier, clang-format, and Shiki, 100% in your browser.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Code Formatter",
  url: "https://localkit.dev/tools/code-formatter",
  description: pageDescription,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "Format JavaScript, JSX, TypeScript, and TSX",
    "Format HTML, Vue, Angular, and Handlebars templates",
    "Format CSS, Less, and SCSS stylesheets",
    "Format JSON, GraphQL, YAML, Markdown, and MDX",
    "Format C, C++, Java, C#, Objective-C, and Protobuf",
    "Syntax highlighting with 20+ themes powered by Shiki",
    "Export beautiful Carbon-style code images",
    "Configurable Prettier and clang-format options",
    "Multiple clang-format style presets (LLVM, Google, Chromium, etc.)",
    "100% client-side processing with WebAssembly",
  ],
  isPartOf: {
    "@type": "WebSite",
    name: "LocalKit",
    url: "https://localkit.dev",
  },
};
---

<Layout title={pageTitle} description={pageDescription} ogImage="https://localkit.dev/og/code-formatter.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full bg-accent-teal/6 blur-[120px]"></div>
      <div class="absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full bg-accent-cyan/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-3xl px-6">
      <!-- Header -->
      <div class="mb-8">
        <a href="/" class="mb-4 inline-flex items-center gap-1.5 text-xs text-text-muted transition-colors hover:text-text-secondary">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Back to tools
        </a>
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-accent-teal/20 bg-accent-teal/10">
            <svg class="h-5 w-5 text-accent-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <div>
            <h1 class="font-display text-2xl font-bold text-text-primary">Code Formatter</h1>
            <p class="text-sm text-text-muted">Format, highlight & export code images in 20+ languages</p>
          </div>
        </div>
      </div>

      <!-- Privacy badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-card bg-bg-secondary px-3 py-1">
        <svg class="h-3.5 w-3.5 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-xs text-text-secondary">100% client-side — nothing leaves your browser</span>
      </div>

      <CodeFormatterApp client:load />
    </div>
  </main>

  <Footer />
</Layout>
