---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import PdfToolsApp from "../../components/pdf-tools/PdfToolsApp";

const pageTitle = "PDF Tools — LocalKit";
const pageDescription =
  "Merge, split, compress, extract, and convert PDF files to images, text, or Word — all processing happens locally in your browser. Your files never leave your device.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "PDF Tools",
  url: "https://localkit.dev/tools/pdf-tools",
  description: pageDescription,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  browserRequirements: "Requires WebAssembly support",
  featureList: [
    "Merge multiple PDF files",
    "Split PDF into individual pages",
    "Extract specific pages from PDF",
    "Convert PDF pages to PNG or JPEG images",
    "Extract text or HTML from PDF",
    "Convert PDF to Word document (.docx)",
    "Compress and optimize PDF file size",
  ],
  isPartOf: {
    "@type": "WebSite",
    name: "LocalKit",
    url: "https://localkit.dev",
  },
};
---

<Layout title={pageTitle} description={pageDescription} ogImage="https://localkit.dev/og/pdf-tools.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full bg-accent-red/6 blur-[120px]"></div>
      <div class="absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full bg-accent-orange/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-6">
      <!-- Header -->
      <div class="mb-8">
        <a href="/" class="mb-4 inline-flex items-center gap-1.5 text-xs text-text-muted transition-colors hover:text-text-secondary">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Back to tools
        </a>
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-accent-red/20 bg-accent-red/10">
            <svg class="h-5 w-5 text-accent-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div>
            <h1 class="font-display text-2xl font-bold text-text-primary">PDF Tools</h1>
            <p class="text-sm text-text-muted">Merge, split, compress, convert, and extract from PDF files</p>
          </div>
        </div>
      </div>

      <!-- Privacy badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-card bg-bg-secondary px-3 py-1">
        <svg class="h-3.5 w-3.5 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-xs text-text-secondary">100% client-side — your PDFs never leave your device</span>
      </div>

      <!-- Info notice about MuPDF WASM -->
      <div class="mb-8 rounded-lg border border-border-card bg-bg-card/60 p-3">
        <p class="text-xs leading-relaxed text-text-muted">
          <span class="font-semibold text-text-secondary">Powered by MuPDF WebAssembly.</span>
          The library loads on first use. All processing happens entirely in your browser — no server, no uploads.
        </p>
      </div>

      <PdfToolsApp client:load />
    </div>
  </main>

  <Footer />
</Layout>
