---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import MarkdownPreviewApp from "../../components/markdown-preview/MarkdownPreviewApp";

const pageTitle = "Markdown Preview — LocalKit";
const pageDescription =
  "Write and preview Markdown in real-time with full GitHub Flavored Markdown support — tables, task lists, code blocks, and more. Export to HTML, 100% in your browser.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Markdown Preview",
  url: "https://localkit.dev/tools/markdown-preview",
  description: pageDescription,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  featureList: [
    "Real-time Markdown rendering",
    "GitHub Flavored Markdown (GFM) support",
    "Tables, task lists, and strikethrough",
    "Fenced code blocks with syntax display",
    "Split, editor-only, and preview-only view modes",
    "Copy Markdown or HTML to clipboard",
    "Export as standalone HTML document",
    "Word, line, and character count",
    "Synchronized scroll in split view",
    "100% client-side processing",
  ],
  isPartOf: {
    "@type": "WebSite",
    name: "LocalKit",
    url: "https://localkit.dev",
  },
};
---

<Layout title={pageTitle} description={pageDescription} ogImage="https://localkit.dev/og/markdown-preview.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full bg-accent-cyan/6 blur-[120px]"></div>
      <div class="absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full bg-accent-teal/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-6">
      <!-- Header -->
      <div class="mb-8">
        <a href="/" class="mb-4 inline-flex items-center gap-1.5 text-xs text-text-muted transition-colors hover:text-text-secondary">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Back to tools
        </a>
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-accent-cyan/20 bg-accent-cyan/10">
            <svg class="h-5 w-5 text-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div>
            <h1 class="font-display text-2xl font-bold text-text-primary">Markdown Preview</h1>
            <p class="text-sm text-text-muted">Real-time render with full GFM support</p>
          </div>
        </div>
      </div>

      <!-- Privacy badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-card bg-bg-secondary px-3 py-1">
        <svg class="h-3.5 w-3.5 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
        <span class="text-xs text-text-secondary">100% client-side — nothing leaves your browser</span>
      </div>

      <MarkdownPreviewApp client:load />
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* ── Markdown preview prose styles ─────────────────────────────── */
  .markdown-preview h1 { font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; margin: 1.5rem 0 0.75rem; line-height: 1.3; }
  .markdown-preview h2 { font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; margin: 1.25rem 0 0.5rem; line-height: 1.35; border-bottom: 1px solid var(--color-border-card); padding-bottom: 0.35rem; }
  .markdown-preview h3 { font-family: var(--font-display); font-size: 1.125rem; font-weight: 600; margin: 1rem 0 0.5rem; }
  .markdown-preview h4 { font-family: var(--font-display); font-size: 1rem; font-weight: 600; margin: 0.75rem 0 0.35rem; }
  .markdown-preview p { margin: 0.65rem 0; line-height: 1.7; }
  .markdown-preview ul, .markdown-preview ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .markdown-preview ul { list-style-type: disc; }
  .markdown-preview ol { list-style-type: decimal; }
  .markdown-preview li { margin: 0.2rem 0; line-height: 1.65; }
  .markdown-preview li > ul, .markdown-preview li > ol { margin: 0.15rem 0; }
  .markdown-preview blockquote { border-left: 3px solid var(--color-accent-cyan, #06b6d4); margin: 0.75rem 0; padding: 0.25rem 0 0.25rem 1rem; color: var(--color-text-secondary); }
  .markdown-preview blockquote p { margin: 0.25rem 0; }
  .markdown-preview code { font-family: var(--font-mono); font-size: 0.85em; background: var(--color-bg-secondary); padding: 0.15em 0.35em; border-radius: 0.25rem; }
  .markdown-preview pre { margin: 0.75rem 0; border-radius: 0.5rem; background: var(--color-bg-secondary); border: 1px solid var(--color-border-card); overflow-x: auto; }
  .markdown-preview pre code { display: block; padding: 0.85rem 1rem; background: none; font-size: 0.8125rem; line-height: 1.6; }
  .markdown-preview a { color: var(--color-accent-cyan, #06b6d4); text-decoration: underline; text-underline-offset: 2px; }
  .markdown-preview a:hover { opacity: 0.8; }
  .markdown-preview img { max-width: 100%; height: auto; border-radius: 0.375rem; margin: 0.5rem 0; }
  .markdown-preview hr { border: none; border-top: 1px solid var(--color-border-card); margin: 1.25rem 0; }
  .markdown-preview table { width: 100%; border-collapse: collapse; margin: 0.75rem 0; font-size: 0.875rem; }
  .markdown-preview th { text-align: left; padding: 0.5rem 0.75rem; border: 1px solid var(--color-border-card); background: var(--color-bg-secondary); font-weight: 600; }
  .markdown-preview td { padding: 0.5rem 0.75rem; border: 1px solid var(--color-border-card); }
  .markdown-preview strong { font-weight: 600; }
  .markdown-preview del { opacity: 0.6; }
  .markdown-preview input[type="checkbox"] { margin-right: 0.35rem; accent-color: var(--color-accent-cyan, #06b6d4); }
  .markdown-preview > :first-child { margin-top: 0; }
</style>
