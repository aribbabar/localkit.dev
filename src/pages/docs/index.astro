---
import { getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import DocSidebar from "../../components/docs/DocSidebar.astro";
import TableOfContents from "../../components/docs/TableOfContents.astro";

const entry = await getEntry("docs", "index");
if (!entry) throw new Error("Missing docs/index.md");

const { Content, headings } = await render(entry);

const pageTitle = `${entry.data.title} — LocalKit Docs`;
const pageDescription = entry.data.description;
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full bg-accent-indigo/6 blur-[120px]"></div>
      <div class="absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full bg-accent-purple/5 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
      <!-- Breadcrumb -->
      <div class="mb-8">
        <nav class="flex items-center gap-1.5 text-xs text-text-muted">
          <a href="/" class="transition-colors hover:text-text-secondary">Home</a>
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
          <span class="text-text-secondary">Docs</span>
        </nav>
      </div>

      <div class="flex gap-10">
        <!-- Left sidebar -->
        <DocSidebar />

        <!-- Main content -->
        <div class="min-w-0 flex-1">
          <header class="mb-10">
            <div class="mb-2 flex items-center gap-2">
              <span class="text-2xl">{entry.data.icon}</span>
              <h1 class="font-display text-3xl font-bold text-text-primary">
                {entry.data.title}
              </h1>
            </div>
            <p class="text-text-secondary">{entry.data.description}</p>
            <div class="mt-3 text-xs text-text-muted">
              Last updated: {entry.data.lastUpdated.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </div>
          </header>

          <article class="prose-doc">
            <Content />
          </article>
        </div>

        <!-- Right TOC -->
        <TableOfContents headings={headings} />
      </div>
    </div>
  </main>

  <Footer />
</Layout>
