---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import DocSidebar from "../../components/docs/DocSidebar.astro";
import TableOfContents from "../../components/docs/TableOfContents.astro";
import DocIcon from "../../components/docs/DocIcon.astro";
import { ChevronRight, ExternalLink, ClipboardCopy, ArrowLeft, ArrowRight } from "@lucide/astro";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs
    .filter((doc) => doc.id !== "index")
    .map((doc) => ({
      params: { slug: doc.id },
      props: { entry: doc },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const pageTitle = `${entry.data.title} — LocalKit Docs`;
const pageDescription = entry.data.description;

// Accent color mapping
const accentBg: Record<string, string> = {
  purple: "bg-accent-purple/6",
  blue: "bg-accent-blue/6",
  red: "bg-accent-red/6",
  cyan: "bg-accent-cyan/6",
  indigo: "bg-accent-indigo/6",
  teal: "bg-accent-teal/6",
};
const accentBg2: Record<string, string> = {
  purple: "bg-accent-purple/5",
  blue: "bg-accent-blue/5",
  red: "bg-accent-red/5",
  cyan: "bg-accent-cyan/5",
  indigo: "bg-accent-indigo/5",
  teal: "bg-accent-teal/5",
};

const bg1 = accentBg[entry.data.accent] || "bg-accent-indigo/6";
const bg2 = accentBg2[entry.data.accent] || "bg-accent-indigo/5";
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <main class="relative pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0">
      <div class={`absolute -top-40 -right-40 h-[400px] w-[400px] rounded-full ${bg1} blur-[120px]`}></div>
      <div class={`absolute -bottom-20 -left-40 h-[300px] w-[300px] rounded-full ${bg2} blur-[100px]`}></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
      <!-- Breadcrumb -->
      <div class="mb-8">
        <nav class="flex items-center gap-1.5 text-xs text-text-muted">
          <a href="/" class="transition-colors hover:text-text-secondary">Home</a>
          <ChevronRight class="h-3 w-3" />
          <a href="/docs" class="transition-colors hover:text-text-secondary">Docs</a>
          <ChevronRight class="h-3 w-3" />
          <span class="text-text-secondary">{entry.data.title}</span>
        </nav>
      </div>

      <div class="flex gap-10">
        <!-- Left sidebar -->
        <DocSidebar currentSlug={entry.id} />

        <!-- Main content -->
        <div class="min-w-0 flex-1">
          <header class="mb-10">
            <div class="mb-2 flex items-center gap-3">
              <DocIcon name={entry.data.icon} size={28} />
              <h1 class="font-display text-3xl font-bold text-text-primary">
                {entry.data.title}
              </h1>
            </div>
            <p class="text-text-secondary">{entry.data.description}</p>
            <div class="mt-3 flex items-center gap-4">
              <span class="text-xs text-text-muted">
                Last updated: {entry.data.lastUpdated.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </span>
              {entry.data.tool && (
                <a
                  href={`/tools/${entry.data.tool}`}
                  class="inline-flex items-center gap-1.5 rounded-full border border-border-card bg-bg-secondary px-3 py-1 text-xs text-text-secondary transition-colors hover:border-border-card-hover hover:text-text-primary"
                >
                  <ExternalLink class="h-3 w-3" />
                  Try this tool
                </a>
              )}
              <button
                id="copy-page-btn"
                type="button"
                class="inline-flex items-center gap-1.5 rounded-full border border-border-card bg-bg-secondary px-3 py-1 text-xs text-text-secondary transition-colors hover:border-border-card-hover hover:text-text-primary"
              >
                <ClipboardCopy class="h-3 w-3" />
                <span id="copy-page-label">Copy page</span>
              </button>
            </div>
          </header>

          <article class="prose-doc">
            <Content />
          </article>

          <!-- Prev/Next navigation -->
          <nav class="mt-16 flex items-center justify-between border-t border-border-card pt-8">
            <a href="/docs" class="group flex items-center gap-2 text-sm text-text-muted transition-colors hover:text-text-primary">
              <ArrowLeft class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" />
              All docs
            </a>
            {entry.data.tool && (
              <a href={`/tools/${entry.data.tool}`} class="group flex items-center gap-2 text-sm text-text-muted transition-colors hover:text-text-primary">
                Open tool
                <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </a>
            )}
          </nav>
        </div>

        <!-- Right TOC -->
        <TableOfContents headings={headings} />
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ rawMarkdown: entry.body }}>
    document.getElementById('copy-page-btn').addEventListener('click', async () => {
      const label = document.getElementById('copy-page-label');
      try {
        await navigator.clipboard.writeText(rawMarkdown);
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy page'; }, 2000);
      } catch {
        label.textContent = 'Failed';
        setTimeout(() => { label.textContent = 'Copy page'; }, 2000);
      }
    });
  </script>
</Layout>
