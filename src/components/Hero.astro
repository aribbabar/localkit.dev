---
// Hero section — main banner with headline, description, and CTAs
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Background effects -->
  <div class="pointer-events-none absolute inset-0">
    <!-- Gradient orbs -->
    <div class="absolute -top-40 -right-40 h-[500px] w-[500px] rounded-full bg-accent-indigo/8 blur-[120px]"></div>
    <div class="absolute -bottom-20 -left-40 h-[400px] w-[400px] rounded-full bg-accent-purple/6 blur-[100px]"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Left content -->
      <div class="flex-1 max-w-2xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-card bg-bg-secondary px-4 py-1.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-green opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-green"></span>
          </span>
          <span class="text-xs font-medium text-text-secondary">Open Source</span>
        </div>

        <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl">
          Your Local,<br />
          Open-Source<br />
          <span class="bg-gradient-to-r from-accent-indigo via-accent-purple to-accent-pink bg-clip-text text-transparent">
            Utility Suite.
          </span>
        </h1>

        <p class="mt-6 max-w-lg text-base leading-relaxed text-text-secondary sm:text-lg">
          Fast, private, and powerful tools for images, video, documents,
          and more. All processing happens on your machine.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href="#tools"
            class="inline-flex items-center gap-2 rounded-lg bg-accent-green px-6 py-3 text-sm font-semibold text-bg-primary transition-all hover:bg-accent-green-hover hover:shadow-[0_0_24px_rgba(34,197,94,0.25)] active:scale-[0.98]"
          >
            Get Started
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center gap-2 rounded-lg border border-border-card px-6 py-3 text-sm font-medium text-text-secondary transition-all hover:border-border-card-hover hover:text-text-primary"
          >
            How it works
          </a>
        </div>
      </div>

      <!-- Right decorative graphic -->
      <div class="flex-1 hidden lg:flex justify-center">
        <div class="relative w-[380px] h-[320px]">
          <!-- Stacked card layers -->
          <div class="absolute top-4 left-4 w-64 h-44 rounded-xl border border-border-card bg-bg-card/60 backdrop-blur-sm shadow-2xl rotate-[-3deg]">
            <div class="p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="h-3 w-3 rounded-full bg-accent-red/80"></div>
                <div class="h-3 w-3 rounded-full bg-accent-orange/80"></div>
                <div class="h-3 w-3 rounded-full bg-accent-green/80"></div>
              </div>
              <div class="space-y-2">
                <div class="h-2 w-3/4 rounded bg-border-card"></div>
                <div class="h-2 w-1/2 rounded bg-border-card"></div>
                <div class="h-2 w-5/6 rounded bg-border-card"></div>
              </div>
            </div>
          </div>
          <div class="absolute top-16 left-24 w-64 h-44 rounded-xl border border-accent-indigo/20 bg-bg-card/80 backdrop-blur-sm shadow-2xl rotate-[2deg]">
            <div class="p-4">
              <div class="flex items-center gap-2 mb-3">
                <div class="h-5 w-5 rounded bg-accent-purple/30 flex items-center justify-center">
                  <svg class="h-3 w-3 text-accent-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14" />
                  </svg>
                </div>
                <div class="h-2 w-20 rounded bg-border-card"></div>
              </div>
              <div class="grid grid-cols-3 gap-2">
                <div class="h-12 rounded-lg bg-accent-indigo/10 border border-accent-indigo/20"></div>
                <div class="h-12 rounded-lg bg-accent-purple/10 border border-accent-purple/20"></div>
                <div class="h-12 rounded-lg bg-accent-pink/10 border border-accent-pink/20"></div>
              </div>
              <div class="mt-3 flex items-center gap-2">
                <div class="h-6 flex-1 rounded-md bg-accent-green/20 border border-accent-green/30 flex items-center justify-center">
                  <span class="text-[9px] font-medium text-accent-green">Convert</span>
                </div>
                <div class="h-6 w-16 rounded-md bg-border-card"></div>
              </div>
            </div>
          </div>
          <!-- Floating accent dots -->
          <div class="absolute top-2 right-12 h-3 w-3 rounded-full bg-accent-green/60 animate-pulse"></div>
          <div class="absolute bottom-8 left-8 h-2 w-2 rounded-full bg-accent-purple/60 animate-pulse [animation-delay:1s]"></div>
          <div class="absolute top-1/2 right-4 h-2.5 w-2.5 rounded-full bg-accent-blue/60 animate-pulse [animation-delay:0.5s]"></div>
        </div>
      </div>
    </div>
  </div>
</section>
