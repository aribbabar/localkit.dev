---
// DropZone - drag & drop area for image files
---

<div
  id="drop-zone"
  class="relative flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-border-card bg-bg-card/40 p-10 text-center transition-all duration-300 hover:border-border-card-hover hover:bg-bg-card/60 cursor-pointer"
>
  <input
    type="file"
    id="file-input"
    multiple
    accept="image/*,.psd,.tga,.bmp,.tiff,.ico,.pcx,.pgm,.ppm,.hdr,.xcf"
    class="absolute inset-0 z-10 cursor-pointer opacity-0"
  />

  <!-- Icon -->
  <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl border border-accent-purple/20 bg-accent-purple/10">
    <svg class="h-7 w-7 text-accent-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
    </svg>
  </div>

  <p class="font-display text-sm font-semibold text-text-primary">
    Drop images here or <span class="text-accent-purple">browse</span>
  </p>
  <p class="mt-1.5 text-xs text-text-muted">
    PNG, JPG, GIF, BMP, TIFF, PSD, ICO, TGA and more
  </p>
  <p class="mt-1 text-xs text-text-muted">
    Multiple files supported for batch conversion
  </p>
</div>
