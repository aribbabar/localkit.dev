---
// ConversionPanel - format selector, options, file list, and convert button
---

<!-- File list -->
<div id="file-list-section" class="hidden">
  <div class="rounded-xl border border-border-card bg-bg-card p-5">
    <!-- Header -->
    <div class="mb-4 flex items-center justify-between">
      <h3 class="font-display text-sm font-semibold text-text-primary">
        Selected Files <span id="file-count" class="text-text-muted">(0)</span>
      </h3>
      <button
        id="clear-files-btn"
        class="text-xs text-text-muted transition-colors hover:text-accent-red"
      >
        Clear all
      </button>
    </div>

    <!-- File entries -->
    <div id="file-list" class="max-h-56 space-y-2 overflow-y-auto pr-1">
      <!-- Populated by JS -->
    </div>
  </div>
</div>

<!-- Conversion settings -->
<div id="settings-section" class="hidden">
  <div class="rounded-xl border border-border-card bg-bg-card p-5">
    <h3 class="font-display mb-4 text-sm font-semibold text-text-primary">Conversion Settings</h3>

    <div class="space-y-4">
      <!-- Output format -->
      <div>
        <label for="output-format" class="mb-1.5 block text-xs font-medium text-text-secondary">
          Output Format
        </label>
        <select
          id="output-format"
          class="w-full rounded-lg border border-border-card bg-bg-secondary px-3 py-2 text-sm text-text-primary outline-none transition-all focus:border-border-card-hover focus:ring-1 focus:ring-border-card-hover"
        >
          <option value="png">PNG</option>
          <option value="jpg">JPEG</option>
          <option value="gif">GIF</option>
          <option value="bmp">BMP</option>
          <option value="tiff">TIFF</option>
          <option value="ico">ICO</option>
          <option value="tga">TGA</option>
          <option value="psd">PSD</option>
          <option value="ppm">PPM</option>
          <option value="pgm">PGM</option>
          <option value="hdr">HDR</option>
          <option value="pcx">PCX</option>
        </select>
      </div>

      <!-- Quality slider (for lossy formats) -->
      <div id="quality-group">
        <label for="quality-slider" class="mb-1.5 flex items-center justify-between text-xs font-medium text-text-secondary">
          <span>Quality</span>
          <span id="quality-value" class="font-mono text-text-muted">90%</span>
        </label>
        <input
          type="range"
          id="quality-slider"
          min="1"
          max="100"
          value="90"
          class="quality-range w-full"
        />
      </div>

      <!-- Resize -->
      <div>
        <label for="resize-input" class="mb-1.5 block text-xs font-medium text-text-secondary">
          Resize <span class="text-text-muted">(optional)</span>
        </label>
        <input
          type="text"
          id="resize-input"
          placeholder="e.g. 800x600 or 50%"
          class="w-full rounded-lg border border-border-card bg-bg-secondary px-3 py-2 text-sm text-text-primary placeholder:text-text-muted outline-none transition-all focus:border-border-card-hover focus:ring-1 focus:ring-border-card-hover"
        />
      </div>

      <!-- Strip metadata -->
      <label class="flex items-center gap-2.5 cursor-pointer">
        <input type="checkbox" id="strip-metadata" class="peer sr-only" />
        <div class="flex h-5 w-5 items-center justify-center rounded border border-border-card bg-bg-secondary transition-colors peer-checked:border-accent-purple peer-checked:bg-accent-purple/20">
          <svg class="hidden h-3 w-3 text-accent-purple peer-checked:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>
        <span class="text-xs text-text-secondary">Strip metadata (EXIF, etc.)</span>
      </label>
    </div>

    <!-- Convert button -->
    <button
      id="convert-btn"
      class="mt-6 flex w-full items-center justify-center gap-2 rounded-lg bg-accent-purple px-5 py-3 text-sm font-semibold text-white transition-all hover:bg-accent-purple/80 hover:shadow-[0_0_24px_rgba(168,85,247,0.25)] active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" />
      </svg>
      Convert
    </button>
  </div>
</div>

<!-- Progress bar -->
<div id="progress-section" class="hidden">
  <div class="rounded-xl border border-border-card bg-bg-card p-5">
    <div class="mb-2 flex items-center justify-between">
      <span class="text-xs font-medium text-text-secondary">Converting...</span>
      <span id="progress-text" class="font-mono text-xs text-text-muted">0/0</span>
    </div>
    <div class="h-2 w-full overflow-hidden rounded-full bg-bg-secondary">
      <div id="progress-bar" class="h-full rounded-full bg-accent-purple transition-all duration-300" style="width: 0%"></div>
    </div>
  </div>
</div>

<!-- Results -->
<div id="results-section" class="hidden">
  <div class="rounded-xl border border-border-card bg-bg-card p-5">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="font-display text-sm font-semibold text-accent-green">Conversion Complete</h3>
      <button
        id="download-all-btn"
        class="inline-flex items-center gap-1.5 rounded-lg border border-accent-green/30 bg-accent-green/10 px-3 py-1.5 text-xs font-medium text-accent-green transition-all hover:bg-accent-green/20"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Download ZIP
      </button>
    </div>
    <div id="results-list" class="space-y-2">
      <!-- Populated by JS -->
    </div>
  </div>
</div>

<style>
  .quality-range {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 3px;
    background: var(--color-bg-secondary);
    outline: none;
  }
  .quality-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-accent-purple);
    cursor: pointer;
    border: 2px solid var(--color-bg-primary);
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.3);
  }
  .quality-range::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-accent-purple);
    cursor: pointer;
    border: 2px solid var(--color-bg-primary);
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.3);
  }
</style>
