---
// ToolsSection — filter tabs + tool cards grid
import ToolCard from "./ToolCard.astro";
import {
  LayoutGrid,
  Image as ImageIcon,
  Video,
  FileText,
  Shield,
  Wrench,
} from "@lucide/astro";

const categories = [
  { id: "all", label: "All Tools", icon: "LayoutGrid" },
  { id: "image", label: "Image", icon: "ImageIcon" },
  { id: "video", label: "Video", icon: "Video" },
  { id: "document", label: "Document", icon: "FileText" },
  { id: "security", label: "Security", icon: "Shield" },
  { id: "tool", label: "Tool", icon: "Wrench" },
];

const categoryIconMap: Record<string, any> = {
  LayoutGrid, ImageIcon, Video, FileText, Shield, Wrench,
};

const tools = [
  {
    title: "Image Converter",
    description: "Batch convert images between PNG, JPG, GIF, BMP, TIFF, and more formats.",
    icon: "Image",
    accentColor: "purple",
    category: "image",
    href: "/tools/image-converter",
  },
  {
    title: "Video Converter",
    description: "Batch convert videos between MP4, WebM, AVI, MKV, MOV, and more using FFmpeg.",
    icon: "Video",
    accentColor: "blue",
    category: "video",
    href: "/tools/video-converter",
  },
  {
    title: "PDF Tools",
    description: "Merge, split, compress, extract pages, and convert PDFs to images or text.",
    icon: "FileType",
    accentColor: "red",
    category: "document",
    href: "/tools/pdf-tools",
  },
  {
    title: "Info Redactor",
    description: "Securely redact sensitive data from documents or images before sharing.",
    icon: "ShieldCheck",
    accentColor: "indigo",
    category: "security",
    href: "/tools/info-redactor",
  },
  {
    title: "Path Converter",
    description: "Convert file paths between forward slashes and backslashes instantly.",
    icon: "Route",
    accentColor: "teal",
    category: "tool",
    href: "/tools/path-converter",
  },
  {
    title: "SVG Viewer",
    description: "Preview SVG code with live rendering, animation playback, zoom, and background modes.",
    icon: "Eye",
    accentColor: "cyan",
    category: "image",
    href: "/tools/svg-viewer",
  },
  {
    title: "Code Formatter",
    description: "Format and beautify 25+ languages — JS, TS, HTML, CSS, C/C++, Java, C#, and more.",
    icon: "Code",
    accentColor: "teal",
    category: "tool",
    href: "/tools/code-formatter",
  },
  {
    title: "Image Metadata",
    description: "View, edit, and strip EXIF, GPS, IPTC, and XMP metadata from images.",
    icon: "ScanSearch",
    accentColor: "purple",
    category: "image",
    href: "/tools/image-metadata",
  },
  {
    title: "Markdown Preview",
    description: "Real-time Markdown render and preview with full GFM support.",
    icon: "FileText",
    accentColor: "cyan",
    category: "document",
    href: "/tools/markdown-preview",
  },
  {
    title: "Password Generator",
    description: "Generate strong, random passwords with customizable length and character options.",
    icon: "KeyRound",
    accentColor: "indigo",
    category: "security",
    href: "/tools/password-generator",
  },
];
---

<section id="tools" class="relative py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Category Filter Tabs -->
    <div class="mb-10 flex flex-wrap items-center gap-2" id="filter-tabs">
      {categories.map((cat, i) => {
        const CatIcon = categoryIconMap[cat.icon];
        return (
          <button
            data-category={cat.id}
            class:list={[
              "filter-tab inline-flex items-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium transition-all duration-200",
              i === 0
                ? "bg-bg-card border border-border-card-hover text-text-primary"
                : "border border-transparent text-text-muted hover:text-text-secondary hover:border-border-card",
            ]}
          >
            {CatIcon && <CatIcon size={14} />}
            {cat.label}
          </button>
        );
      })}
    </div>

    <!-- Tools Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" id="tools-grid">
      {tools.map((tool) => (
        <div data-category={tool.category}>
          <ToolCard
            title={tool.title}
            description={tool.description}
            icon={tool.icon}
            accentColor={tool.accentColor}
            href={tool.href}
          />
        </div>
      ))}

      <!-- Request a Tool Card -->
      <a
        href="#"
        class="group flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-border-card p-5 text-center transition-all duration-300 hover:border-border-card-hover hover:bg-bg-card/50"
      >
        <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full border border-border-card bg-bg-secondary transition-colors group-hover:border-border-card-hover">
          <svg class="h-5 w-5 text-text-muted transition-colors group-hover:text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <span class="font-display text-sm font-semibold text-text-secondary">Request a Tool</span>
        <span class="mt-1 text-xs text-text-muted">Suggest what we should build next</span>
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>(".filter-tab");
    const cards = document.querySelectorAll<HTMLElement>("#tools-grid > [data-category]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const category = tab.dataset.category;

        // Update active tab styles
        tabs.forEach((t) => {
          t.classList.remove("bg-bg-card", "border-border-card-hover", "text-text-primary");
          t.classList.add("border-transparent", "text-text-muted");
        });
        tab.classList.add("bg-bg-card", "border-border-card-hover", "text-text-primary");
        tab.classList.remove("border-transparent", "text-text-muted");

        // Filter cards
        cards.forEach((card) => {
          if (category === "all" || card.dataset.category === category) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  });
</script>
