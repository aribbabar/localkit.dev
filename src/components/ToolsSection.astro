---
// ToolsSection — filter tabs + tool cards grid
import ToolCard from "./ToolCard.astro";

const categories = [
  { id: "all", label: "All Tools", icon: "⚡" },
  { id: "image", label: "Image", icon: "🖼" },
  { id: "video", label: "Video", icon: "🎬" },
  { id: "document", label: "Document", icon: "📄" },
  { id: "security", label: "Security", icon: "🔒" },
  { id: "tool", label: "Tool", icon: "🔧" },
];

const tools = [
  {
    title: "Image Converter",
    description: "Batch convert images between PNG, JPG, WebP, and AVIF formats.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>`,
    accentColor: "purple",
    category: "image",
  },
  {
    title: "Video Compressor",
    description: "Reduce video file size without significant quality loss using FFmpeg local processing.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>`,
    accentColor: "blue",
    category: "video",
  },
  {
    title: "PDF Merger",
    description: "Combine multiple PDF documents into a single file quickly and easily.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    accentColor: "red",
    category: "document",
  },
  {
    title: "Info Redactor",
    description: "Securely redact sensitive data from documents or images before sharing.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    accentColor: "indigo",
    category: "security",
  },
  {
    title: "JSON Formatter",
    description: "Parses, prettifies, and validates JSON structures with instant feedback.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    accentColor: "teal",
    category: "tool",
  },
  {
    title: "EXIF Remover",
    description: "Strip metadata and EXIF tags from your photos to protect your privacy.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>`,
    accentColor: "orange",
    category: "image",
  },
  {
    title: "Markdown Preview",
    description: "Real-time Markdown render and preview with full GFM support.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>`,
    accentColor: "cyan",
    category: "document",
  },
];
---

<section id="tools" class="relative py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Category Filter Tabs -->
    <div class="mb-10 flex flex-wrap items-center gap-2" id="filter-tabs">
      {categories.map((cat, i) => (
        <button
          data-category={cat.id}
          class:list={[
            "filter-tab inline-flex items-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium transition-all duration-200",
            i === 0
              ? "bg-bg-card border border-border-card-hover text-text-primary"
              : "border border-transparent text-text-muted hover:text-text-secondary hover:border-border-card",
          ]}
        >
          <span class="text-xs">{cat.icon}</span>
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Tools Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" id="tools-grid">
      {tools.map((tool) => (
        <div data-category={tool.category}>
          <ToolCard
            title={tool.title}
            description={tool.description}
            icon={tool.icon}
            accentColor={tool.accentColor}
          />
        </div>
      ))}

      <!-- Request a Tool Card -->
      <a
        href="#"
        class="group flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-border-card p-5 text-center transition-all duration-300 hover:border-border-card-hover hover:bg-bg-card/50"
      >
        <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full border border-border-card bg-bg-secondary transition-colors group-hover:border-border-card-hover">
          <svg class="h-5 w-5 text-text-muted transition-colors group-hover:text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <span class="font-display text-sm font-semibold text-text-secondary">Request a Tool</span>
        <span class="mt-1 text-xs text-text-muted">Suggest what we should build next</span>
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>(".filter-tab");
    const cards = document.querySelectorAll<HTMLElement>("#tools-grid > [data-category]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const category = tab.dataset.category;

        // Update active tab styles
        tabs.forEach((t) => {
          t.classList.remove("bg-bg-card", "border-border-card-hover", "text-text-primary");
          t.classList.add("border-transparent", "text-text-muted");
        });
        tab.classList.add("bg-bg-card", "border-border-card-hover", "text-text-primary");
        tab.classList.remove("border-transparent", "text-text-muted");

        // Filter cards
        cards.forEach((card) => {
          if (category === "all" || card.dataset.category === category) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  });
</script>
