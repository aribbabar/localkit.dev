---
// Footer — site footer with links and branding
const currentYear = new Date().getFullYear();

const ghRepo = "https://github.com/aribbabar/localkit.dev";

const footerSections = [
  {
    title: "Product",
    links: [
      { label: "Tools", href: "/#tools" },
      { label: "Documentation", href: "/docs" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "GitHub Repo", href: ghRepo },
      { label: "Discussions", href: `${ghRepo}/discussions` },
    ],
  },
  {
    title: "Links",
    links: [
      { label: "Releases", href: `${ghRepo}/releases` },
      { label: "Changelog", href: `${ghRepo}/blob/main/CHANGELOG.md` },
    ],
  },
];
---

<footer class="border-t border-border-card bg-bg-primary">
  <div class="mx-auto max-w-7xl px-6 py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
      <!-- Left — brand -->
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/favicon.svg" alt="LocalKit logo" class="h-7 w-7" />
          <span class="font-display text-base font-semibold text-text-primary">LocalKit</span>
        </a>
        <p class="mt-3 text-xs leading-relaxed text-text-muted">
          Building the ultimate local toolbox for developers and creators.
        </p>
      </div>

      <!-- Right — link columns -->
      <div class="flex flex-wrap gap-16">
        {footerSections.map((section) => (
          <div>
            <h4 class="font-display text-xs font-semibold uppercase tracking-wider text-text-secondary mb-4">
              {section.title}
            </h4>
            <ul class="space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-muted transition-colors hover:text-text-primary"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-border-card pt-8">
      <p class="text-xs text-text-muted">
        &copy; {currentYear} LocalKit Project &middot; Privacy-first tools &middot; Source code available on GitHub (AGPL-3.0).
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/aribbabar/localkit.dev" target="_blank" rel="noopener noreferrer" class="text-text-muted transition-colors hover:text-text-primary">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
        <a href="https://www.buymeacoffee.com/aribf" target="_blank" rel="noopener noreferrer">
          <img src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png" alt="Buy Me A Coffee" class="h-8 rounded" />
        </a>
      </div>
    </div>
  </div>
</footer>
