---
// Navbar component — top navigation bar with logo, search, and links
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border-card bg-bg-primary/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="relative flex h-8 w-8 items-center justify-center">
        <img src="/favicon.svg" alt="LocalKit logo" class="h-8 w-8 transition-transform duration-300 group-hover:scale-110" />
      </div>
      <span class="font-display text-lg font-semibold tracking-tight text-text-primary">
        LocalKit
      </span>
    </a>

    <!-- Search Bar -->
    <div class="hidden md:flex flex-1 max-w-md mx-8">
      <div class="relative w-full group">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
          <svg class="h-4 w-4 text-text-muted transition-colors group-focus-within:text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <input
          type="text"
          placeholder="Search for tools, features..."
          class="w-full rounded-lg border border-border-card bg-bg-secondary py-2 pl-10 pr-4 text-sm text-text-primary placeholder:text-text-muted outline-none transition-all focus:border-border-card-hover focus:ring-1 focus:ring-border-card-hover"
        />
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
          <kbd class="rounded border border-border-card bg-bg-primary px-1.5 py-0.5 font-mono text-[10px] text-text-muted">
            Ctrl K
          </kbd>
        </div>
      </div>
    </div>

    <!-- Right Links -->
    <div class="flex items-center gap-6">
      <a href="/docs" class="hidden sm:block text-sm text-text-secondary transition-colors hover:text-text-primary">
        Documentation
      </a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-sm text-text-secondary transition-colors hover:text-text-primary"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </div>
</nav>
